# Schwab Trader API — read-only Phase 5 connector
# Create a personal-use app at https://developer.schwab.com/
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_REDIRECT_URI=https://localhost:8080/callback

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BOARD_MARKET_KEY=

# ── LIVE TRADING (real money) ──────────────────────────────────────────────
# OFF by default. Real orders are impossible unless this is exactly true AND
# you have completed the Schwab OAuth login AND set the account hash below.
LIVE_TRADING_ENABLED=false
# Hard ceiling on TOTAL real capital the bot may ever deploy. Start at $100 and
# raise it only after the model earns it. The engine never exceeds this.
LIVE_CAPITAL_CAP=100
# The funded Schwab account to trade. Get the hash from GET /trader/v1/accounts
# (the "hashValue"). Required before any live order is routed.
SCHWAB_ACCOUNT_HASH=
